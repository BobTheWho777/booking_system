```gitignore
# Compiled and binary files
*.pyc
__pycache__/
*.o
*.obj
*.exe
*.dll
*.so
*.class

# Dependencies
node_modules/
venv/
.venv/
.env
.env.local
.env.*

# Build artifacts
dist/
build/
target/

# Logs and temporary files
*.log
*.tmp
*.swp
*.swo

# Coverage reports
coverage/
htmlcov/
.coverage

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo

# System files
.DS_Store
Thumbs.db

# Cache directories
.mypy_cache/
.pytest_cache/
.gradle/
```